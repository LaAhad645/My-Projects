void viewW(int A[20][3])
{
	int Ecount=0, Fcount=0;
	for(int i=0 ; i<20 ; i++)
	{
		for(int j=0 ; j<3 ; j++)
			if(A[i][j]==0)
				Ecount++;

			else if(A[i][j]==1)
				Fcount++;
	}
	printf("\nThe ward has %d empty bed(s) and %d full beds.\n", Ecount, Fcount);
}

int main()
{
